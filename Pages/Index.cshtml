@page
@model Wms.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h5 class="mb-1">Tổng quan WMS</h5>
        <div class="text-muted" style="font-size:13px;">Theo dõi tồn kho, nhập/xuất và hiệu suất vận hành.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary btn-sm" asp-page="/Import/Index">Import dữ liệu</a>
        <a class="btn btn-outline-secondary btn-sm" asp-page="/Skus/Index">Vào danh mục</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-title">Tổng SKU</div>
            <div class="kpi-value">@Model.TotalSkus</div>
            <div class="kpi-sub">Danh mục mặt hàng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-title">Tổng Bin</div>
            <div class="kpi-value">@Model.TotalBins</div>
            <div class="kpi-sub">Vị trí lưu trữ</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-title">Tồn hiện tại</div>
            <div class="kpi-value">@Model.TotalOnHand</div>
            <div class="kpi-sub">Tổng số lượng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-title">Phát sinh hôm nay</div>
            <div class="kpi-value">@Model.TodayMovements</div>
            <div class="kpi-sub">Nhập/Xuất</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="cardx">
            <div class="cardx-header">Gợi ý công việc</div>
            <ul class="mb-0">
                <li>Nhập kho: tạo phiếu nhập và đưa hàng vào vị trí.</li>
                <li>Xuất kho: soạn hàng theo đơn và xuất hàng.</li>
                <li>Kiểm kê: chạy cycle count theo khu vực.</li>
            </ul>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="cardx">
            <div class="cardx-header">Truy cập nhanh</div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary btn-sm" asp-page="/Skus/Index">Mặt hàng</a>
                <a class="btn btn-outline-secondary btn-sm" asp-page="/Bins/Index">Vị trí</a>
                <a class="btn btn-outline-secondary btn-sm" asp-page="/Inventory/OnHand">Tồn kho</a>
                <a class="btn btn-outline-secondary btn-sm" asp-page="/Inbound/Receive">Nhập kho</a>
            </div>
        </div>
    </div>
</div>